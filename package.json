{
	"name": "nps-survey",
	"version": "1.0.21",
	"description": "",
	"main": "index.js",
	"scripts": {
		"start": "wp-scripts start --entry=./src --output-path=./dist",
		"build": "wp-scripts build --entry=./src --output-path=./dist",
		"i18n": "grunt textdomain && wp i18n make-pot languages/nps-survey.pot --domain=nps-survey --debug",
		"pretty": "prettier --check .",
		"pretty:fix": "prettier --write .",
		"lint-js": "wp-scripts lint-js",
		"lint-js:fix": "npm run pretty:fix && npm run lint-js -- --fix",
		"lint-css": "wp-scripts lint-style --allow-empty-input",
		"lint-css:fix": "npm run lint-css -- --fix",
		"lint-pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses",
		"format": "wp-scripts format",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:md:js": "wp-scripts lint-md-js",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"plugin-zip": "wp-scripts plugin-zip",
		"test:e2e": "wp-scripts test-e2e",
		"test:unit": "wp-scripts test-unit-js",
		"package": "sh bin/build.sh",
		"release": "npm run build && npm run package",
		"insights": "./vendor/bin/phpinsights analyse -v --no-interaction",
		"insights:fix": "./vendor/bin/phpinsights analyse --fix --no-interaction"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/brainstormforce/nps-survey.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/brainstormforce/nps-survey/issues"
	},
	"homepage": "https://github.com/brainstormforce/nps-survey#readme",
	"devDependencies": {
		"@heroicons/react": "^2.1.1",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/forms": "^0.5.7",
		"@tailwindcss/typography": "^0.5.10",
		"@wordpress/eslint-plugin": "^9.3.0",
		"@wordpress/prettier-config": "^1.1.1",
		"@wordpress/scripts": "^27.4.0",
		"autoprefixer": "^10.4.18",
		"clsx": "^2.1.0",
		"css-loader": "^7.1.4",
		"grunt": "^1.4.1",
		"grunt-bumpup": "^0.6.3",
		"grunt-cli": "^1.4.3",
		"grunt-contrib-clean": "^2.0.0",
		"grunt-contrib-compress": "^2.0.0",
		"grunt-contrib-copy": "^1.0.0",
		"grunt-text-replace": "^0.4.0",
		"grunt-wp-i18n": "^1.0.3",
		"postcss": "^8.5.8",
		"postcss-nested": "^6.0.1",
		"postcss-scss": "^4.0.9",
		"prettier": "npm:wp-prettier@^3.0.3",
		"sass": "^1.69.4",
		"sass-loader": "^13.3.2",
		"style-loader": "^1.3.0",
		"tailwind-merge": "^2.0.0",
		"tailwindcss": "^3.4.4",
		"wp-prettier": "^2.6.2",
		"zustand": "^4.5.2"
	}
}
